{
  "appId": "com.musicplayer.app",
  "productName": "音乐播放器",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "extraResources": [
    {
      "from": "public/icon.png",
      "to": "icon.png"
    },
    {
      "from": "public/tray-icon.png",
      "to": "tray-icon.png"
    },
    {
      "from": "public/tray-icon@2x.png",
      "to": "tray-icon@2x.png"
    }
  ],
  "win": {
    "target": ["nsis"],
    "icon": "public/icon.ico",
    "signAndEditExecutable": false,
    "sign": null,
    "certificateSubjectName": null,
    "certificateSha1": null
  },
  "mac": {
    "target": ["dmg"],
    "icon": "public/icon.png",
    "category": "public.app-category.music",
    "identity": null
  },
  "nsis": {
    "artifactName": "MusicPlayer-${version}-Setup.exe",
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "音乐播放器",
    "uninstallDisplayName": "音乐播放器",
    "installerIcon": "public/icon.ico",
    "uninstallerIcon": "public/icon.ico"
  }
}
