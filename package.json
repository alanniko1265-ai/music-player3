    "@vitejs/plugin-vue": "^5.0.3",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "fast-check": "^3.15.0",
    "jsdom": "^29.1.1",
    "sass": "^1.70.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.0",
